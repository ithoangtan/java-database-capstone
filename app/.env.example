# Copy to .env and adjust. Used by: docker run --env-file .env ...
# Backend-only (DBs on host, Docker Desktop Windows/Mac):
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/cms?useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_DATA_MONGODB_URI=mongodb://host.docker.internal:27017/prescriptions
